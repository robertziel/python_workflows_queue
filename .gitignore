# Type / lint caches
.mypy_cache/
.ruff_cache/

# Local env / secrets — the DB DSN lives in env vars; never commit a real one
.env
.env.*
!.env.example

# Editor / OS cruft
.idea/
.vscode/
.DS_Store
*.swp
